{
  "name": "@nenb/cogs",
  "version": "0.0.0",
  "private": true,
  "description": "Secure, minimal, VM-isolated personal assistant built on Pi",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.19.0 <23"
  },
  "scripts": {
    "check": "npm run format:check && npm run typecheck && npm run test && npm run schemas && npm run images:check && npm run lock:check && npm run licenses && npm run audit",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "test:pi": "tsx --test test/pi-embedding.test.ts",
    "schemas": "tsx scripts/validate-schemas.ts",
    "images:check": "tsx scripts/check-image-pins.ts",
    "lock:check": "tsx scripts/check-lock-integrity.ts",
    "licenses": "tsx scripts/check-licenses.ts",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.6",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "typebox": "1.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@grpc/grpc-js": "1.14.4",
    "@types/node": "22.20.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3"
  }
}
