{
  "version": "cogs.integration/v1alpha1",
  "id": "pypi",
  "preset_revision": "sha256:a8eb4dc0483c17bfefd4fa6f9f27d1b06bc77bb5a2f49a17bd95e5b825340f49",
  "dns": {
    "mode": "proxy-connect-authority",
    "guest_resolution": false
  },
  "rules": [
    {
      "name": "pypi-index",
      "host": "pypi.org",
      "port": 443,
      "methods": ["GET"],
      "path_patterns": ["/simple/*/", "/pypi/*/json"],
      "path_policy": {
        "strategy": "segment-glob",
        "normalization": "reject-ambiguous"
      },
      "query_policy": {
        "mode": "deny"
      },
      "redirects": {
        "mode": "deny",
        "max_hops": 0,
        "allowed_hosts": []
      },
      "inject_auth": true
    },
    {
      "name": "pypi-files",
      "host": "files.pythonhosted.org",
      "port": 443,
      "methods": ["GET"],
      "path_patterns": ["/packages"],
      "path_policy": {
        "strategy": "prefix",
        "normalization": "reject-ambiguous"
      },
      "query_policy": {
        "mode": "deny"
      },
      "redirects": {
        "mode": "deny",
        "max_hops": 0,
        "allowed_hosts": []
      },
      "inject_auth": false
    }
  ],
  "auth": {
    "type": "basic_header",
    "header": "Authorization",
    "placeholder": "COGS_PLACEHOLDER_PYPI_BASIC",
    "secret_handle": "users/preset-user/integrations/pypi"
  }
}
