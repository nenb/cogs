{
  "version": "cogs.integration/v1alpha1",
  "id": "npm",
  "preset_revision": "sha256:d4be179781e348da4d13e34608a8c85a9a2fa4ea52ce2afb4ecc62897b687bc4",
  "dns": {
    "mode": "proxy-connect-authority",
    "guest_resolution": false
  },
  "rules": [
    {
      "name": "npm-registry-metadata",
      "host": "registry.npmjs.org",
      "port": 443,
      "methods": ["GET"],
      "path_patterns": ["/*", "/@*/*"],
      "path_policy": {
        "strategy": "segment-glob",
        "normalization": "reject-ambiguous"
      },
      "query_policy": {
        "mode": "deny"
      },
      "redirects": {
        "mode": "deny",
        "max_hops": 0,
        "allowed_hosts": []
      },
      "inject_auth": true
    },
    {
      "name": "npm-package-tarballs",
      "host": "registry.npmjs.org",
      "port": 443,
      "methods": ["GET"],
      "path_patterns": ["/*/-/*.tgz", "/@*/*/-/*.tgz"],
      "path_policy": {
        "strategy": "segment-glob",
        "normalization": "reject-ambiguous"
      },
      "query_policy": {
        "mode": "deny"
      },
      "redirects": {
        "mode": "deny",
        "max_hops": 0,
        "allowed_hosts": []
      },
      "inject_auth": true
    }
  ],
  "auth": {
    "type": "bearer_header",
    "header": "Authorization",
    "prefix": "Bearer ",
    "placeholder": "COGS_PLACEHOLDER_NPM_TOKEN",
    "secret_handle": "users/preset-user/integrations/npm"
  }
}
