{
  "version": "cogs.integration/v1alpha1",
  "id": "github-smart-http",
  "preset_revision": "sha256:48154e1e0d1b978188b8b0aeead1d928b103630883f1ff9bf9b9e2e3868a7f8b",
  "dns": {
    "mode": "proxy-connect-authority",
    "guest_resolution": false
  },
  "rules": [
    {
      "name": "github-smart-http-refs",
      "host": "github.com",
      "port": 443,
      "methods": ["GET"],
      "path_patterns": ["/*/*.git/info/refs"],
      "path_policy": {
        "strategy": "segment-glob",
        "normalization": "reject-ambiguous"
      },
      "query_policy": {
        "mode": "exact",
        "values": ["service=git-upload-pack"]
      },
      "redirects": {
        "mode": "deny",
        "max_hops": 0,
        "allowed_hosts": []
      },
      "inject_auth": true
    },
    {
      "name": "github-smart-http-upload-pack",
      "host": "github.com",
      "port": 443,
      "methods": ["POST"],
      "path_patterns": ["/*/*.git/git-upload-pack"],
      "path_policy": {
        "strategy": "segment-glob",
        "normalization": "reject-ambiguous"
      },
      "query_policy": {
        "mode": "deny"
      },
      "redirects": {
        "mode": "deny",
        "max_hops": 0,
        "allowed_hosts": []
      },
      "inject_auth": true
    }
  ],
  "auth": {
    "type": "basic_header",
    "header": "Authorization",
    "placeholder": "COGS_PLACEHOLDER_GITHUB_BASIC",
    "secret_handle": "users/preset-user/integrations/github"
  }
}
