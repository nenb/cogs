{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogs.dev/schemas/policy-decision-v1alpha1.json",
  "title": "Cogs policy decision envelope",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "decision_id", "allow", "reason"],
      "properties": {
        "version": { "const": "cogs.policy-decision/v1alpha1" },
        "decision_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "allow": { "const": true },
        "reason": { "const": "allowed" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "decision_id", "allow", "reason"],
      "properties": {
        "version": { "const": "cogs.policy-decision/v1alpha1" },
        "decision_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "allow": { "const": false },
        "reason": {
          "enum": ["unknown_action", "invalid_envelope", "unsupported_surface", "restore_reserved", "mode_denied"]
        }
      }
    }
  ]
}
