{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogs.dev/schemas/security-report-v1alpha1.json",
  "title": "Cogs applicability-aware security evidence report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "report_id",
    "source_revision",
    "profile",
    "authority",
    "started_at",
    "completed_at",
    "environment",
    "components",
    "dependencies",
    "tests",
    "known_limitations"
  ],
  "properties": {
    "version": { "const": "cogs.security-report/v1alpha1" },
    "report_id": { "$ref": "#/$defs/opaqueId" },
    "source_revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "profile": { "enum": ["insecure-container", "macos-vm-dev", "linux-kvm", "single-ec2", "eks-kata"] },
    "authority": { "enum": ["functional-only", "authoritative-local", "authoritative-production-profile"] },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture", "runner", "runtime_versions"],
      "properties": {
        "os": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "runner": { "type": "string", "minLength": 1 },
        "runner_image": { "type": "string" },
        "runtime_versions": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }, { "type": "null" }]
          }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "image_digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authorization", "audit", "revocation", "identity", "network_enforcement"],
      "properties": {
        "authorization": { "$ref": "#/$defs/dependency" },
        "audit": { "$ref": "#/$defs/dependency" },
        "revocation": { "$ref": "#/$defs/dependency" },
        "identity": { "$ref": "#/$defs/dependency" },
        "network_enforcement": { "$ref": "#/$defs/dependency" }
      }
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/testResult" }
    },
    "known_limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "allOf": [
    {
      "if": {
        "properties": { "profile": { "enum": ["insecure-container", "macos-vm-dev"] } },
        "required": ["profile"]
      },
      "then": { "properties": { "authority": { "const": "functional-only" } } }
    },
    {
      "if": { "properties": { "profile": { "const": "linux-kvm" } }, "required": ["profile"] },
      "then": {
        "properties": {
          "environment": {
            "type": "object",
            "required": ["metadata"],
            "properties": {
              "metadata": {
                "type": "object",
                "required": ["kvm_present", "kvm_enabled", "guest_root", "distinct_boot_ids"],
                "properties": {
                  "kvm_present": { "const": true },
                  "kvm_enabled": { "const": true },
                  "guest_root": { "const": true },
                  "distinct_boot_ids": { "const": true }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "opaqueId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "dependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "implementation"],
      "properties": {
        "mode": { "enum": ["real", "stubbed", "not-applicable"] },
        "implementation": { "type": "string", "minLength": 1 },
        "version": { "type": "string" }
      }
    },
    "skipApproval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "reason", "review_at"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "review_at": { "type": "string", "format": "date-time" }
      }
    },
    "testResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "group", "result", "release_eligible", "dependency_modes"],
      "properties": {
        "id": { "$ref": "#/$defs/opaqueId" },
        "group": { "type": "string", "minLength": 1 },
        "result": { "enum": ["pass", "fail", "stubbed", "not-applicable", "skipped-with-approved-reason"] },
        "release_eligible": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "dependency_modes": {
          "type": "object",
          "additionalProperties": { "enum": ["real", "stubbed", "not-applicable"] }
        },
        "diagnostics_redacted": { "type": "string" },
        "skip_approval": { "$ref": "#/$defs/skipApproval" }
      },
      "allOf": [
        {
          "if": { "properties": { "result": { "const": "skipped-with-approved-reason" } }, "required": ["result"] },
          "then": { "required": ["skip_approval"], "properties": { "release_eligible": { "const": false } } },
          "else": { "not": { "required": ["skip_approval"] } }
        },
        {
          "if": {
            "properties": { "result": { "enum": ["stubbed", "not-applicable", "fail"] } },
            "required": ["result"]
          },
          "then": { "properties": { "release_eligible": { "const": false } } }
        }
      ]
    }
  }
}
