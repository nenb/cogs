{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogs.dev/schemas/git-mapping-v1alpha1.json",
  "title": "Cogs trusted record of an untrusted Git observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "repo", "commit", "session", "entry", "turn", "observed_at", "confidence"],
  "properties": {
    "version": { "const": "cogs.git-mapping/v1alpha1" },
    "repo": { "$ref": "#/$defs/opaqueId" },
    "commit": {
      "type": "string",
      "oneOf": [{ "pattern": "^[a-f0-9]{40}$" }, { "pattern": "^[a-f0-9]{64}$" }]
    },
    "session": { "$ref": "#/$defs/opaqueId" },
    "entry": { "type": "string", "pattern": "^[a-f0-9]{8}$" },
    "turn": { "type": "integer", "minimum": 0 },
    "observed_at": { "type": "string", "format": "date-time" },
    "confidence": { "enum": ["exact", "inferred-ancestor", "checkpoint"] },
    "checkpoint_ref": { "type": "string", "pattern": "^refs/cogs/sessions/[A-Za-z0-9][A-Za-z0-9._:-]*/[0-9]+$" }
  },
  "allOf": [
    {
      "if": { "properties": { "confidence": { "const": "checkpoint" } }, "required": ["confidence"] },
      "then": { "required": ["checkpoint_ref"] },
      "else": { "not": { "required": ["checkpoint_ref"] } }
    }
  ],
  "$defs": {
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    }
  }
}
