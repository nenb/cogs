{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogs.dev/schemas/egress-case-manifest-v1alpha1.json",
  "title": "Cogs egress conformance case manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "cases"],
  "properties": {
    "version": { "const": "cogs.egress-cases/v1alpha1" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "opaqueId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "group", "timeout_ms", "profiles", "dependencies"],
      "properties": {
        "id": { "$ref": "#/$defs/opaqueId" },
        "group": {
          "enum": [
            "identity-route",
            "http-parsing",
            "credential-handling",
            "bypass-resistance",
            "audit-failure",
            "revocation",
            "client-compatibility"
          ]
        },
        "timeout_ms": { "type": "integer", "minimum": 100, "maximum": 300000 },
        "profiles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["insecure-container", "macos-vm-dev", "linux-kvm"] }
        },
        "dependencies": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["authorization", "audit", "revocation", "identity", "network_enforcement"]
          }
        }
      }
    }
  }
}
