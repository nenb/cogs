{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cogs.invalid/schemas/aws-feasibility-report-v1alpha1.json",
  "title": "Cogs AWS Feasibility Evidence v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "authority", "result", "source_revision", "region", "expires_at", "launch", "runtime"],
  "properties": {
    "version": { "const": "cogs.aws-feasibility-evidence/v1alpha1" },
    "authority": { "const": "aws-feasibility" },
    "result": { "enum": ["pass", "fail"] },
    "source_revision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "region": { "const": "us-east-1" },
    "expires_at": { "type": "string", "format": "date-time" },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instance_type",
        "image_id",
        "architecture",
        "hypervisor",
        "root_device_type",
        "imds_v2",
        "ephemeral_public_ip",
        "nested_virtualization",
        "vcpu",
        "memory_mib",
        "bare_metal",
        "gpu"
      ],
      "properties": {
        "instance_type": { "const": "c8i-flex.large" },
        "image_id": { "type": "string", "pattern": "^ami-[0-9a-f]+$" },
        "architecture": { "const": "x86_64" },
        "hypervisor": { "enum": ["nitro", "xen"] },
        "root_device_type": { "const": "ebs" },
        "imds_v2": { "const": true },
        "ephemeral_public_ip": { "const": true },
        "nested_virtualization": { "const": "enabled" },
        "vcpu": { "const": 2 },
        "memory_mib": { "const": 4096 },
        "bare_metal": { "const": false },
        "gpu": { "const": false }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "result",
        "host_kernel",
        "guest_kernel",
        "guest_root",
        "cpu_vmx",
        "kvm_device",
        "qmp_kvm_present",
        "qmp_kvm_enabled",
        "containerd_version",
        "qemu_version",
        "kata_runtime_version",
        "kata_archive_sha256",
        "package_setup_ms",
        "kata_boot_ms"
      ],
      "properties": {
        "version": { "const": "cogs.aws-runtime-result/v1alpha1" },
        "result": { "enum": ["pass", "fail"] },
        "host_kernel": { "type": "string", "minLength": 1, "maxLength": 128 },
        "guest_kernel": { "type": "string", "minLength": 1, "maxLength": 128 },
        "guest_root": { "const": true },
        "cpu_vmx": { "const": true },
        "kvm_device": { "const": true },
        "qmp_kvm_present": { "const": true },
        "qmp_kvm_enabled": { "const": true },
        "containerd_version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "qemu_version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "kata_runtime_version": { "type": "string", "minLength": 1, "maxLength": 256 },
        "kata_archive_sha256": {
          "const": "1449ecea50bd91fa73a94648db195d18950fe869ba4b1f12d05f55f1fa7c1b01"
        },
        "package_setup_ms": { "type": "integer", "minimum": 1, "maximum": 2700000 },
        "kata_boot_ms": { "type": "integer", "minimum": 1, "maximum": 600000 }
      }
    }
  }
}
